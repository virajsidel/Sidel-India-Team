<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <Element ID="SSLConfiguration" Type="SSLCFG">
    <Selector ID="SSLCfgType" Value="OpcUaServerSslCfg">
      <Group ID="OwnCertificate">
        <Property ID="OwnCertificate" Value="MyOpcUaCert.cer" />
        <Property ID="OwnCertificatePrivateKey" Value="MyOpcUaServerKey.key" />
      </Group>
      <Selector ID="ValidateCommBuddy" Value="off" />
    </Selector>
  </Element>
</Configuration>